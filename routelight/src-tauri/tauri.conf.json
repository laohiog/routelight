{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RouteLight",
  "version": "0.1.0",
  "identifier": "com.laohi.routelight",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "RouteLight",
        "width": 360,
        "height": 790,
        "minWidth": 340,
        "minHeight": 560,
        "resizable": true,
        "decorations": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' asset: data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "template": "nsis/installer-template.nsi",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false,
        "installerHooks": "nsis/hooks.nsh"
      }
    }
  }
}
